A 0.1 255,255,255
C 0,0,0 0,0,-1 60
L 2,3,1 0.8 255,255,255

# Square (two triangles) shifted to the left and further back (Z = -4)
tr -2.2,-0.5,-4 -0.2,-0.5,-4 -0.2,0.5,-4 255,50,50
tr -2.2,-0.5,-4 -0.2,0.5,-4 -2.2,0.5,-4 50,200,50

# Tilted triangle closer in the center (Z = -2)
tr 0,-0.5,-2 0.8,0.8,-2 -0.8,0.8,-2 50,50,200
