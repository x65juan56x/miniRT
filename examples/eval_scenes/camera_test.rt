A 0.3 255,255,255

# General view
C 0,1,-7 0,0,1 90
# x
#C 0,0,0 1,0,0 90
# y
#C 0,0,0 0,1,0 90
# z
#C 0,0,0 0,0,1 90

L -0,0,0 0.4 255,255,255

# Camera at origin and 3 spheres around on a plane y=-1

# Floor plane at y = -1
pl 0,-1,0 0,1,0 180,180,180

# Spheres (center, diameter, color)
# Large (resting on the plane: y = -1 + radius = -1 + 1.5 = 0.5)
sp 0.0,0.5,7.5 3.0 80,80,200
# Medium (y = -1 + 1.2/2 = 0.2)
sp 4.5,0.2,1.5 2.4 200,80,80
sp 1,4,0 2.4 200,200,200
# Small (y = -1 + 1.2/2 = -0.4 + 0.6 = -0.4)
sp -2.5,-0.4,3.0 1.2 80,200,180